{
  "name": "google-sheet-products-for-shop",
  "version": "0.1.3",
  "tablePrefix": "gsp_",
  "description": "Mirrors your shop catalogue into a Google Sheet you can bulk-edit, then pull the changes back in.",
  "requiresCoreVersion": "0.5.486",
  "requiresModules": [
    { "name": "shop", "minVersion": "0.1.57" },
    { "name": "shop-variations", "minVersion": "0.1.15" }
  ],
  "permissions": ["googlesheets.manage"],
  "navEntries": [],
  "settingsTabs": [
    {
      "id": "google-sheet-products-for-shop",
      "label": "Google Sheet",
      "permission": "googlesheets.manage",
      "import": "./components/SettingsTab",
      "component": "GoogleSheetSettingsTab"
    }
  ],
  "extensionPoints": [],
  "requiredEnvVars": [
    { "name": "ENCRYPTION_KEY", "required": true },
    { "name": "SITE_URL", "required": true }
  ],
  "cookieCategories": [],
  "teardown": ["gsp_connection", "gsp_sync_log"],
  "cronJobs": []
}
